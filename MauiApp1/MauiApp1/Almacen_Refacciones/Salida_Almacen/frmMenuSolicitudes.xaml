<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="iAlmacen.Almacen_Refacciones.Salida_Almacen.frmMenuSolicitudes"
             Title="Salidas Almacen">
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <ImageButton Source="ImagenFull/SolicitudesS.jpeg" Aspect="AspectFill" Clicked="Solicitudes_Clicked" />
            <Label Margin="0,0,10,0" HorizontalTextAlignment="End" Text="Solicitudes" TextColor="White" FontSize="35" FontAttributes="Bold" VerticalOptions="End" />

            <ImageButton Grid.Row="1" Source="ImagenFull/EntradaS.jpg" Aspect="AspectFill" Clicked="Salidas_Clicked" />
            <Label Margin="0,0,10,0" HorizontalTextAlignment="End" Grid.Row="1" Text="Salidas" TextColor="White" FontSize="35" FontAttributes="Bold" VerticalOptions="End" />
        </Grid>
    </ContentPage.Content>
</ContentPage>