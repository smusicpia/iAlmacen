<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="iAlmacen.Almacen_Refacciones.Salida_Almacen.Orden_Recoleccion"
             xmlns:local="clr-namespace:iAlmacen.ViewModels">
    <ContentPage.BindingContext>
        <local:Orden_RecoleccionViewModel />
    </ContentPage.BindingContext>
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="81" />
                <RowDefinition />
                <RowDefinition Height="0" />
                <RowDefinition Height="65" />
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0" Grid.ColumnSpan="2">
                <Grid RowSpacing="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="25" />
                        <RowDefinition Height="0" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <!--<Picker x:Name="cbSucursal" Grid.Column="1" Grid.Row="1" Title="SUCURSAL" ItemsSource="{Binding Sucursales}" ItemDisplayBinding="{Binding Descripcion}" SelectedItem="{Binding Clave}" SelectedIndexChanged="cbSucursal_SelectedIndexChanged" />-->
                    <Picker x:Name="cbSucursal" Grid.Column="1" Grid.Row="1" Title="SUCURSAL" SelectedIndexChanged="cbSucursal_SelectedIndexChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>MÉRIDA</x:String>
                                <x:String>TEBEC</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <Picker x:Name="cbArea" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="3" Title="AREA" SelectedIndexChanged="cbArea_SelectedIndexChanged" />
                    <Picker x:Name="cbNivel1" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2" Title="C.C. NIVEL 1" SelectedIndexChanged="cbNivel1_SelectedIndexChanged" />
                    <Picker x:Name="cbNivel2" Grid.Column="3" Grid.Row="2" Grid.ColumnSpan="2" Title="C.C. NIVEL 2" SelectedIndexChanged="cbNivel2_SelectedIndexChanged" />
                    <Picker x:Name="cbNivel3" Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="2" Title="C.C. NIVEL 3" SelectedIndexChanged="cbNivel3_SelectedIndexChanged" />
                    <Picker x:Name="cbNivel4" Grid.Column="3" Grid.Row="3" Grid.ColumnSpan="2" Title="C.C. NIVEL 4" />
                </Grid>
            </StackLayout>
            <StackLayout Grid.Row="1" Grid.ColumnSpan="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="7*" />
                        <RowDefinition Height="93*" />
                    </Grid.RowDefinitions>
                    <StackLayout Grid.Row="0" HeightRequest="20" Margin="0">
                        <Border Padding="10,0,10,5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="10*" />
                                    <RowDefinition Height="10*" />
                                    <RowDefinition Height="10*" />
                                </Grid.RowDefinitions>
                                <StackLayout Grid.Row="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10*" />
                                            <ColumnDefinition Width="90*" />
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Text="CLAVE" TextColor="Gray" />
                                        <Label Grid.Column="1" Text="DESCRIPCION" TextColor="Gray" />
                                    </Grid>
                                </StackLayout>
                                <StackLayout Grid.Row="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="25*" />
                                            <ColumnDefinition Width="25*" />
                                            <ColumnDefinition Width="25*" />
                                            <ColumnDefinition Width="25*" />
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Text="MARCA" TextColor="Gray" />
                                        <Label Grid.Column="1" Text="MEDIDA" TextColor="Gray" />
                                        <Label Grid.Column="2" Text="No. PARTE" TextColor="Gray" />
                                        <Label Grid.Column="3" Text="CANTIDAD" TextColor="Gray" />
                                    </Grid>
                                </StackLayout>
                                <StackLayout Grid.Row="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="15*" />
                                            <ColumnDefinition Width="15*" />
                                            <ColumnDefinition Width="30*" />
                                            <ColumnDefinition Width="12*" />
                                            <ColumnDefinition Width="12*" />
                                            <ColumnDefinition Width="15*" />
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Text="SECCION" TextColor="Gray" />
                                        <Label Grid.Column="1" Text="PASILLO" HorizontalTextAlignment="Center" TextColor="Gray" />
                                        <Label Grid.Column="2" Text="ESTANTERIA" TextColor="Gray" />
                                        <Label Grid.Column="3" Text="NIVEL" HorizontalTextAlignment="Center" TextColor="Gray" />
                                        <Label Grid.Column="4" Text="TARIMA" HorizontalTextAlignment="Center" TextColor="Gray" />
                                        <Label Grid.Column="5" Text="CONTENEDOR" HorizontalTextAlignment="Center" TextColor="Gray" />
                                    </Grid>
                                </StackLayout>
                            </Grid>
                        </Border>
                    </StackLayout>
                    <StackLayout Grid.Row="1">
                        <ScrollView>
                            <StackLayout>
                                <RefreshView Command="{Binding LoadItemsCommand_vigilancia}" IsRefreshing="{Binding IsBusy}" RefreshColor="#872200">
                                    <CollectionView ItemsSource="{Binding Items}" SelectionMode="Single" SelectionChanged="CollectionView_SelectionChanged">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <SwipeView>
                                                    <SwipeView.RightItems>
                                                        <SwipeItem Text="ELIMINAR" IsDestructive="True" CommandParameter="{Binding folio_orden_}" BackgroundColor="#F83A52" Clicked="imEliminar_Clicked" />
                                                    </SwipeView.RightItems>
                                                    <StackLayout HeightRequest="60" Margin="0" Padding="10,0,10,5">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="9*" />
                                                                <RowDefinition Height="9*" />
                                                                <RowDefinition Height="9*" />
                                                            </Grid.RowDefinitions>
                                                            <StackLayout Grid.Row="0">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="10*" />
                                                                        <ColumnDefinition Width="90*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Label Grid.Column="0" FontAttributes="Bold" FontSize="Small" TextColor="#3E3E3E" Margin="0,0,0,0" Text="{Binding codigo_articulo}" />
                                                                    <Label Grid.Column="1" FontAttributes="Bold" FontSize="Small" TextColor="#3E3E3E" Margin="0,0,0,0" Text="{Binding descripcion_general}" />
                                                                </Grid>
                                                            </StackLayout>
                                                            <StackLayout Grid.Row="1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="25*" />
                                                                        <ColumnDefinition Width="25*" />
                                                                        <ColumnDefinition Width="25*" />
                                                                        <ColumnDefinition Width="25*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Label Grid.Column="0" TextColor="#3E3E3E" Text="{Binding desc_marca}" />
                                                                    <Label Grid.Column="1" TextColor="#3E3E3E" Text="{Binding desc_medida}" />
                                                                    <Label Grid.Column="2" TextColor="#3E3E3E" Text="{Binding desc_parte}" />
                                                                    <Label Grid.Column="3" TextColor="red" Text="{Binding cantidad}" />
                                                                </Grid>
                                                            </StackLayout>
                                                            <StackLayout Grid.Row="2">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="15*" />
                                                                        <ColumnDefinition Width="15*" />
                                                                        <ColumnDefinition Width="30*" />
                                                                        <ColumnDefinition Width="12*" />
                                                                        <ColumnDefinition Width="12*" />
                                                                        <ColumnDefinition Width="15*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Label Grid.Column="0" TextColor="Gray" Text="{Binding desc_seccion}" />
                                                                    <Label Grid.Column="1" TextColor="Gray" HorizontalTextAlignment="Center" Text="{Binding Pasillo}" />
                                                                    <Label Grid.Column="2" TextColor="Gray" Text="{Binding desc_estanteria}" />
                                                                    <Label Grid.Column="3" TextColor="Gray" HorizontalTextAlignment="Center" Text="{Binding Nivel}" />
                                                                    <Label Grid.Column="4" TextColor="Gray" HorizontalTextAlignment="Center" Text="{Binding Tarima}" />
                                                                    <Label Grid.Column="5" TextColor="Gray" HorizontalTextAlignment="Center" Text="{Binding Contenedor}" />
                                                                </Grid>
                                                            </StackLayout>
                                                        </Grid>
                                                    </StackLayout>
                                                </SwipeView>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </RefreshView>
                            </StackLayout>
                        </ScrollView>
                    </StackLayout>
                </Grid>
            </StackLayout>
            <StackLayout x:Name="salida2" Grid.Row="3" Grid.ColumnSpan="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <!--<Button x:Name="btnRefacciones" Text="AGREGAR REFACCIONES" FontSize="Large" Clicked="btnAgregarItems_Clicked" />-->
                    <Button x:Name="btnGenerarListaRecoleccion" Text="GUARDAR LISTA RECOLECCION" Grid.Column="1" FontSize="Large" Clicked="btnGuardarListaRecoleccion_Clicked" />
                </Grid>
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>