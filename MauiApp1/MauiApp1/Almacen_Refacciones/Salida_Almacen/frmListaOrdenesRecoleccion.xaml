<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="iAlmacen.Almacen_Refacciones.Salida_Almacen.frmListaOrdenesRecoleccion"
             Title="Ordenes de Recoleccion">
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="95*" />
                <RowDefinition Height="7*" />
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0" Padding="10">
                <Border>
                    <StackLayout HeightRequest="45" BackgroundColor="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="11*" />
                                <ColumnDefinition Width="15*" />
                                <ColumnDefinition Width="11*" />
                                <ColumnDefinition Width="8*" />
                                <ColumnDefinition Width="14*" />
                                <ColumnDefinition Width="13*" />
                                <ColumnDefinition Width="10*" />
                            </Grid.ColumnDefinitions>
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="0" Text="Recoleccion" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="1" Text="Orden Compra" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="2" Text="Fecha" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="3" Text="Hora" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="4" Text="Usuario" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="5" Text="Requisicion" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="6" Text="Cotizacion" />
                        </Grid>
                    </StackLayout>
                </Border>
                <ScrollView>
                    <StackLayout>
                        <RefreshView Command="{Binding LoadItemsCommand_recoleccion}" IsRefreshing="{Binding IsBusy}" RefreshColor="#872200">
                            <CollectionView ItemsSource="{Binding Items}" SelectionMode="Single" SelectionChanged="CollectionView_SelectionChanged">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <SwipeView>
                                            <SwipeView.RightItems>
                                                <SwipeItem Text="Cancelar Recoleccion" IsDestructive="True" CommandParameter="{Binding id_}" BackgroundColor="#F83A52" Clicked="OnCancel_entrada" />
                                            </SwipeView.RightItems>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="11*" />
                                                    <ColumnDefinition Width="15*" />
                                                    <ColumnDefinition Width="11*" />
                                                    <ColumnDefinition Width="8*" />
                                                    <ColumnDefinition Width="14*" />
                                                    <ColumnDefinition Width="13*" />
                                                    <ColumnDefinition Width="10*" />
                                                </Grid.ColumnDefinitions>
                                                <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="0" Text="{Binding id_}" />
                                                <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="1" Text="{Binding folio_orden_}" />
                                                <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="2" Text="{Binding fecha_pedido_}" />
                                                <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="3" Text="{Binding hora_pedido_}" />
                                                <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="4" Text="{Binding usuario_pedido_}" />
                                                <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="5" Text="{Binding folio_requisicion_}" />
                                                <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="6" Text="{Binding folio_cotizacion_}" />
                                            </Grid>
                                        </SwipeView>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </RefreshView>
                    </StackLayout>
                </ScrollView>
            </StackLayout>
            <StackLayout Grid.Row="1" BackgroundColor="#FAA61A" HeightRequest="125" Padding="35" Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="50*" />
                    </Grid.ColumnDefinitions>
                    <!--<Button Grid.Column="0" Text="Folio Manual" TextColor="White" FontSize="25" Clicked="clicked_folio_manual" />-->
                    <Button Grid.Column="1" BackgroundColor="#872200" Text="Actualizar" TextColor="White" FontSize="25" Clicked="Actualizar_lista_event" />
                </Grid>
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>