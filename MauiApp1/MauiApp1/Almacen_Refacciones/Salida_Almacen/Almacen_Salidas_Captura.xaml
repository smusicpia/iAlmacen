<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="iAlmacen.Almacen_Refacciones.Salida_Almacen.Almacen_Salidas_Captura">
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10*" />
                <RowDefinition Height="30*" />
                <RowDefinition Height="40*" />
                <RowDefinition Height="20*" />
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0" Orientation="Horizontal" HorizontalOptions="Center" VerticalOptions="Center">
                <StackLayout VerticalOptions="Center">
                    <Label Text="Articulo" TextColor="Gray" />
                </StackLayout>
                <StackLayout VerticalOptions="Center">
                    <Entry Placeholder="Codigo" WidthRequest="100" />
                </StackLayout>
                <StackLayout Padding="20,0,0,0">
                    <Button Text="Ayuda" />
                </StackLayout>
                <StackLayout Padding="20,0,0,0">
                    <Button Text="ScaSnnear" />
                </StackLayout>
            </StackLayout>
            <StackLayout Grid.Row="1" Orientation="Vertical">
                <StackLayout Padding="50,0,0,0">
                    <Label Text="Descripcion: " TextColor="Gray" />
                    <Label Text="xxxx" TextColor="Gray" />
                </StackLayout>
                <StackLayout Padding="50,0,0,0">
                    <Label Text="Medida: " TextColor="Gray" />
                    <Label Text="xxxx" TextColor="Gray" />
                </StackLayout>
                <StackLayout Padding="50,0,0,0">
                    <Label Text="Marca: " TextColor="Gray" />
                    <Label Text="xxxx" TextColor="Gray" />
                </StackLayout>
                <StackLayout Padding="50,0,0,0">
                    <Label Text="Parte: " TextColor="Gray" />
                    <Label Text="xxxx" TextColor="Gray" />
                </StackLayout>
            </StackLayout>
            <StackLayout Grid.Row="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="33*" />
                        <RowDefinition Height="33*" />
                        <RowDefinition Height="33*" />
                    </Grid.RowDefinitions>
                    <StackLayout Grid.Row="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50*" />
                                <ColumnDefinition Width="50*" />
                            </Grid.ColumnDefinitions>
                            <StackLayout Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Padding="100,10,0,0">
                                <Label Text="Cantidad" TextColor="Gray" />
                                <Entry Placeholder="0" WidthRequest="100" />
                            </StackLayout>
                            <StackLayout Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Padding="0,10,0,0">
                                <Label Text="Unidad" TextColor="Gray" />
                                <Picker WidthRequest="200" />
                            </StackLayout>
                            <StackLayout Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Padding="115,10,0,0">
                                <Label Text="Nivel 3" TextColor="Gray" />
                                <Picker WidthRequest="200" />
                            </StackLayout>
                            <StackLayout Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Padding="0,10,0,0">
                                <Label Text="Nivel 4" TextColor="Gray" />
                                <Picker WidthRequest="200" />
                            </StackLayout>
                            <StackLayout Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Padding="180,10,0,0">
                                <Label Text="Reponer: " FontSize="Medium" TextColor="Gray" />
                                <Label Text="No " FontSize="Medium" TextColor="Gray" />
                                <Switch x:Name="sw_ubicacion" />
                                <Label Text=" Si" FontSize="Medium" TextColor="Gray" />
                            </StackLayout>
                        </Grid>
                    </StackLayout>
                </Grid>
            </StackLayout>
            <StackLayout Grid.Row="3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="50*" />
                    </Grid.ColumnDefinitions>
                    <StackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" Padding="0,20,0,0">
                        <Button Text="Agregar" FontSize="30" />
                    </StackLayout>
                    <StackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center" Padding="0,20,0,0">
                        <Button Text="Guardar" FontSize="30" />
                    </StackLayout>
                </Grid>
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>