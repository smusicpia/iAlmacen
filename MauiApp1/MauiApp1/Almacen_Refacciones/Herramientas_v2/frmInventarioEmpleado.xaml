<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:iAlmacen.ViewModels"
    x:Class="iAlmacen.Almacen_Refacciones.Herramientas_v2.frmInventarioEmpleado">
    <ContentPage.BindingContext>
        <vm:ItemsViewModel_ArticuloEnResguardo />
    </ContentPage.BindingContext>
    <ContentPage.Content>
        <StackLayout>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="6*" />
                    <RowDefinition Height="93*" />
                </Grid.RowDefinitions>
                <StackLayout Grid.Row="0" Margin="0" Padding="0" BackgroundColor="#FAA61A">
                    <Border Margin="0" Padding="15,0,0,0" HeightRequest="55">
                        <Grid Margin="0" Padding="0">
                            <StackLayout Margin="0" Padding="0">
                                <Grid Margin="0" Padding="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="33*" />
                                        <RowDefinition Height="33*" />
                                        <RowDefinition Height="33*" />
                                    </Grid.RowDefinitions>
                                    <StackLayout Grid.Row="0" Margin="0" Padding="0" HeightRequest="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="33*" />
                                                <ColumnDefinition Width="33*" />
                                                <ColumnDefinition Width="34*" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0" Text="Resguardo" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                            <Label Grid.Column="1" Text="Entregado" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                            <Label Grid.Column="2" Text="Condicion" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                        </Grid>
                                    </StackLayout>
                                    <StackLayout Grid.Row="1" Margin="0" Padding="0" HeightRequest="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="10*" />
                                                <ColumnDefinition Width="70*" />
                                                <ColumnDefinition Width="20*" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0" Text="Codigo" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                            <Label Grid.Column="1" Text="Descripcion" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                            <Label Grid.Column="2" Text="Numero Serie" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                        </Grid>
                                    </StackLayout>
                                    <StackLayout Grid.Row="2" Margin="0" Padding="0" HeightRequest="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="33*" />
                                                <ColumnDefinition Width="33*" />
                                                <ColumnDefinition Width="34*" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0" Text="Medida" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                            <Label Grid.Column="1" Text="Marca" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                            <Label Grid.Column="2" Text="Parte" FontSize="15" TextColor="#006b5e" Margin="0" Padding="0" />
                                        </Grid>
                                    </StackLayout>
                                </Grid>
                            </StackLayout>
                        </Grid>
                    </Border>
                </StackLayout>
                <StackLayout Grid.Row="1">
                    <ScrollView>
                        <StackLayout>
                            <CollectionView ItemsSource="{Binding Items}" SelectionMode="Single">
                                <CollectionView.EmptyView>
                                    <ContentView>
                                        <StackLayout>
                                            <Label Text="Sin Registros Actualmente" HorizontalOptions="Center" VerticalOptions="Center" TextColor="DarkSlateGray" FontSize="Medium" />
                                        </StackLayout>
                                    </ContentView>
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <SwipeView>
                                            <SwipeView.RightItems>
                                                <SwipeItem Text="Extraviado" IsDestructive="True" CommandParameter="{Binding id}" BackgroundColor="#872200" Clicked="btnExtraviado_Clicked" />
                                                <SwipeItem Text="Devolucion" IsDestructive="False" CommandParameter="{Binding id}" BackgroundColor="#872200" Clicked="btnDevolucion_Clicked" />
                                                <SwipeItem Text="Resguardo" IsDestructive="False" CommandParameter="{Binding id}" BackgroundColor="#872200" Clicked="btnResguardo_Clicked" />
                                            </SwipeView.RightItems>
                                            <StackLayout Margin="0" Padding="0">
                                                <Grid Margin="0" Padding="0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="33*" />
                                                        <RowDefinition Height="33*" />
                                                        <RowDefinition Height="33*" />
                                                    </Grid.RowDefinitions>
                                                    <StackLayout Grid.Row="0" Margin="0" Padding="0" HeightRequest="15">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="33*" />
                                                                <ColumnDefinition Width="33*" />
                                                                <ColumnDefinition Width="33*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Label Grid.Column="0" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="red" FontSize="Small" Margin="15,0,0,0" Padding="0" Text="{Binding folio}" />
                                                            <Label Grid.Column="1" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="red" FontSize="Small" Margin="0,0,0,0" Padding="0" Text="{Binding fechaentregado}" />
                                                            <Label Grid.Column="2" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="red" FontSize="Small" Margin="0,0,0,0" Padding="0" Text="{Binding condicion}" />
                                                            <Image Grid.Column="3" />
                                                        </Grid>
                                                    </StackLayout>
                                                    <StackLayout Grid.Row="1" Margin="0" Padding="0" HeightRequest="15">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="10*" />
                                                                <ColumnDefinition Width="70*" />
                                                                <ColumnDefinition Width="20*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Label Grid.Column="0" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="15,0,0,0" Padding="0" Text="{Binding codigo}" />
                                                            <Label Grid.Column="1" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="0,0,0,0" Padding="0" Text="{Binding descripcion}" />
                                                            <Label Grid.Column="2" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="Blue" FontSize="Small" Margin="0,0,0,0" Padding="0" Text="{Binding serie}" />
                                                            <Image Grid.Column="3" />
                                                        </Grid>
                                                    </StackLayout>
                                                    <StackLayout Grid.Row="2" Margin="0" Padding="0" HeightRequest="15">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="33*" />
                                                                <ColumnDefinition Width="33*" />
                                                                <ColumnDefinition Width="30*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Label Grid.Column="0" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="15,0,0,0" Padding="0" Text="{Binding medida}" />
                                                            <Label Grid.Column="1" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="0,0,0,0" Padding="0" Text="{Binding marca}" />
                                                            <Label Grid.Column="2" VerticalTextAlignment="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="0,0,0,0" Padding="0" Text="{Binding parte}" />
                                                            <Image Grid.Column="3" />
                                                        </Grid>
                                                    </StackLayout>
                                                </Grid>
                                            </StackLayout>
                                        </SwipeView>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </StackLayout>
                    </ScrollView>
                </StackLayout>
            </Grid>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>