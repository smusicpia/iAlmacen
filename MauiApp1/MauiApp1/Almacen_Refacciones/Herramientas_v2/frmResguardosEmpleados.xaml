<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:iAlmacen.ViewModels"
    x:Class="iAlmacen.Almacen_Refacciones.Herramientas_v2.frmResguardosEmpleados"
    Title="Resguardos Empleados">
    <ContentPage.BindingContext>
        <vm:ItemsViewModel_ResgEmpleado />
    </ContentPage.BindingContext>
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5*" />
                <RowDefinition Height="95*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0">
                <Grid HeightRequest="60">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100*" />
                    </Grid.RowDefinitions>
                    <StackLayout Grid.Row="0" IsVisible="True" BackgroundColor="#FAA61A" x:Name="PanelFamilias" Margin="0,0,0,0" Padding="0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="10*" />
                                <ColumnDefinition Width="10*" />
                                <ColumnDefinition Width="50*" />
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="10*" />
                            </Grid.ColumnDefinitions>
                            <Label HorizontalOptions="Center" VerticalOptions="Center" FontSize="Subtitle" Grid.Column="1" TextColor="Black" Text="Area" />
                            <Picker x:Name="cbArea" Grid.Column="2" />
                            <Button x:Name="btnBuscar" FontSize="Subtitle" Text="Buscar" BackgroundColor="#872200" TextColor="White" Grid.Column="3" Clicked="btnBuscar_Clicked" />
                        </Grid>
                    </StackLayout>
                </Grid>
            </StackLayout>
            <StackLayout Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20*" />
                        <RowDefinition Height="90*" />
                    </Grid.RowDefinitions>
                    <Border HeightRequest="60" Padding="0,10">
                        <StackLayout Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10*" />
                                    <ColumnDefinition Width="60*" />
                                    <ColumnDefinition Width="10*" />
                                    <ColumnDefinition Width="20*" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="Clave" TextColor="#006b5e" />
                                <Label Grid.Column="1" Text="Empleado" TextColor="#006b5e" />
                                <Label Grid.Column="2" Text="No. Articulos" TextColor="#006b5e" />
                                <Label Grid.Column="3" Text="Inventariado" TextColor="#006b5e" />
                            </Grid>
                        </StackLayout>
                    </Border>
                    <StackLayout Grid.Row="1" Margin="0,0,0,0" Padding="0">
                        <ScrollView>
                            <StackLayout>
                                <CollectionView ItemsSource="{Binding Items}" SelectionMode="Single" SelectionChanged="CollectionView_SelectionChanged">
                                    <CollectionView.EmptyView>
                                        <ContentView>
                                            <StackLayout>
                                                <Label Text="Sin Registros Actualmente" HorizontalOptions="Center" VerticalOptions="Center" TextColor="DarkSlateGray" FontSize="Medium" />
                                            </StackLayout>
                                        </ContentView>
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <SwipeView>
                                                <SwipeView.RightItems>
                                                    <SwipeItem Text="Cerrar" IsDestructive="True" CommandParameter="{Binding clave}" BackgroundColor="#F83A52" Clicked="btnCerrar_Clicked" />
                                                </SwipeView.RightItems>
                                                <StackLayout HeightRequest="45" Margin="0" Padding="0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="10*" />
                                                            <ColumnDefinition Width="60*" />
                                                            <ColumnDefinition Width="10*" />
                                                            <ColumnDefinition Width="20*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="15,15,0,0" Text="{Binding clave}" />
                                                        <Label Grid.Column="1" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="0,15,0,0" Text="{Binding empleado}" />
                                                        <Label Grid.Column="2" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="0,15,0,0" Text="{Binding articulos}" />
                                                        <Label Grid.Column="3" FontAttributes="Bold" TextColor="#3E3E3E" FontSize="Small" Margin="0,15,0,0" Text="{Binding fecha}" />
                                                    </Grid>
                                                </StackLayout>
                                            </SwipeView>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </StackLayout>
                        </ScrollView>
                    </StackLayout>
                </Grid>
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>