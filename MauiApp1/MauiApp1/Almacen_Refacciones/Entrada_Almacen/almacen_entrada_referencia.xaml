<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="iAlmacen.almacen_entrada_referencia"
             Title="Entradas Sin Documento Factura">
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="95*" />
                <!--                <RowDefinition Height="10*" />-->
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0" Padding="0" HeightRequest="10">
                <Frame HasShadow="false" BorderColor="Silver">
                    <StackLayout HeightRequest="15" BackgroundColor="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                            </Grid.ColumnDefinitions>
                            <Label FontSize="Medium" Margin="0" TextColor="Teal" HorizontalTextAlignment="Center" Grid.Column="0" Text="Orden Compra" />
                            <Label FontSize="Medium" Margin="0" TextColor="Teal" HorizontalTextAlignment="Center" Grid.Column="1" Text="Entrada" />
                            <Label FontSize="Medium" Margin="0" TextColor="Teal" HorizontalTextAlignment="Center" Grid.Column="2" Text="Fecha" />
                            <Label FontSize="Medium" Margin="0" TextColor="Teal" HorizontalTextAlignment="Center" Grid.Column="3" Text="Proveedor" />
                            <Label FontSize="Medium" Margin="0" TextColor="Teal" HorizontalTextAlignment="Center" Grid.Column="4" Text="Almacenista" />
                        </Grid>
                    </StackLayout>
                </Frame>
                <ListView x:Name="ItemsListView" ItemsSource="{Binding Items}" VerticalOptions="FillAndExpand" HasUnevenRows="true" IsPullToRefreshEnabled="false" IsRefreshing="{Binding IsBusy, Mode=OneWay}" CachingStrategy="RecycleElement" ItemSelected="OnItemSelected">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <ViewCell.ContextActions>
                                    <!--<MenuItem Clicked="OnMore" CommandParameter="{Binding .}" Text="More" />-->
                                    <!--                                    <MenuItem Clicked="OnCancel_entrada" Text="Cancelar Vigilancia" IsDestructive="true" CommandParameter="{Binding folio_orden_}" />-->
                                </ViewCell.ContextActions>
                                <StackLayout HeightRequest="40">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20*" />
                                            <ColumnDefinition Width="20*" />
                                            <ColumnDefinition Width="20*" />
                                            <ColumnDefinition Width="20*" />
                                            <ColumnDefinition Width="20*" />
                                        </Grid.ColumnDefinitions>
                                        <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="0" Text="{Binding folio_orden_}" />
                                        <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="1" Text="{Binding captura_}" />
                                        <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="2" Text="{Binding fecha_}" />
                                        <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="3" Text="{Binding proveedor_}" />
                                        <Label FontSize="Medium" Margin="0,5,0,0" HorizontalTextAlignment="Center" Grid.Column="4" Text="{Binding vigilante_}" />
                                    </Grid>
                                </StackLayout>
                                <!--                                <StackLayout Padding="5">
                                    <Label Text="{Binding folio_orden_}" LineBreakMode="WordWrap" Style="{DynamicResource ListItemTextStyle}" FontSize="Small" />
                                    <Label Text="{Binding folio_orden_}" LineBreakMode="NoWrap" Style="{DynamicResource ListItemDetailTextStyle}" FontSize="Small" />
                                </StackLayout>-->
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackLayout>
            <!-- <StackLayout Grid.Row="1" BackgroundColor="Teal" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="50*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Text="Agregar Factura" TextColor="White" FontSize="25" Clicked="clicked_folio_manual" />
                    </Grid>
            </StackLayout>-->
        </Grid>
    </ContentPage.Content>
</ContentPage>