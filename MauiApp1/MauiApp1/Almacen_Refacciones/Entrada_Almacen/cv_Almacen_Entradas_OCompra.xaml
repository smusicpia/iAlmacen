<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:iAlmacen"
             xmlns:vm="clr-namespace:iAlmacen.ViewModels"
             x:Class="iAlmacen.cv_Almacen_Entradas_OCompra"
             Title="Entradas por Vigilancia">
    <ContentPage.BindingContext>
        <vm:ItemsViewModel_Vigilancia />
    </ContentPage.BindingContext>
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="95*" />
                <RowDefinition Height="7*" />
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0" Padding="10">
                <Border>
                    <StackLayout HeightRequest="45" BackgroundColor="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                                <ColumnDefinition Width="20*" />
                            </Grid.ColumnDefinitions>
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="0" Text="Orden Compra" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="1" Text="Fecha" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="2" Text="Hora" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="3" Text="Proveedor" />
                            <Label FontSize="Medium" Margin="0,10,0,0" TextColor="#006b5e" HorizontalTextAlignment="Center" Grid.Column="4" Text="Vigilante" />
                        </Grid>
                    </StackLayout>
                </Border>
                <ScrollView>
                    <StackLayout>
                        <RefreshView Command="{Binding LoadItemsCommand_vigilancia}" IsRefreshing="{Binding IsBusy}" RefreshColor="#872200">
                            <CollectionView ItemsSource="{Binding Items}" SelectionMode="Single" SelectionChanged="CollectionView_SelectionChanged">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <SwipeView>
                                            <SwipeView.RightItems>
                                                <SwipeItem Text="Rechazar" IsDestructive="True" CommandParameter="{Binding folio_orden_}" BackgroundColor="#F83A52" Clicked="OnCancel_entrada" />
                                            </SwipeView.RightItems>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20*" />
                                                    <ColumnDefinition Width="20*" />
                                                    <ColumnDefinition Width="20*" />
                                                    <ColumnDefinition Width="20*" />
                                                    <ColumnDefinition Width="20*" />
                                                </Grid.ColumnDefinitions>
                                                <Label FontSize="Medium" Margin="0,0,0,0" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Grid.Column="0" Text="{Binding folio_orden_}" />
                                                <Label FontSize="Medium" Margin="0,0,0,0" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Grid.Column="1" Text="{Binding fecha_}" />
                                                <Label FontSize="Medium" Margin="0,0,0,0" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Grid.Column="2" Text="{Binding hora_}" />
                                                <Label FontSize="Medium" Margin="0,0,0,0" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Grid.Column="3" Text="{Binding proveedor_}" />
                                                <Label FontSize="Medium" Margin="0,0,0,0" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Grid.Column="4" Text="{Binding vigilante_}" />
                                            </Grid>
                                        </SwipeView>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </RefreshView>
                    </StackLayout>
                </ScrollView>
            </StackLayout>
            <StackLayout Grid.Row="1" BackgroundColor="#FAA61A" HeightRequest="125" Padding="35">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="50*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Text="Folio Manual" BackgroundColor="#872200" TextColor="White" FontSize="25" Clicked="clicked_folio_manual" />
                    <!--<Button x:Name="folio_manual" Grid.Column="0" Text="Folio Manual" TextColor="White" FontSize="25" />-->
                    <Button Grid.Column="1" Text="Actualizar" BackgroundColor="#872200" TextColor="White" FontSize="25" Clicked="Actualizar_lista_event" />
                </Grid>
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>