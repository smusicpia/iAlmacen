<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="iAlmacen.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:iAlmacen"
    xmlns:views="clr-namespace:iAlmacen.Views"
    Shell.FlyoutBehavior="Flyout"
    Shell.BackgroundColor="#FAA61A"
    Shell.FlyoutWidth="250"
    FlyoutHeaderBehavior="CollapseOnScroll"
    Title="MauiApp1">

    <Shell.FlyoutHeader>
        <StackLayout Padding="20">
            <Image Source="name.png" HeightRequest="80" Aspect="AspectFit" HorizontalOptions="Center" />
            <!--<Label Text="Aplicaciones Mapsa" FontSize="Medium" FontAttributes="Bold" HorizontalTextAlignment="Center" Margin="0,10,0,0" />-->
        </StackLayout>
    </Shell.FlyoutHeader>

    <ShellContent Title="Almacen Refacciones" Icon="control_mapsa.ico" ContentTemplate="{DataTemplate views:MainView}" />
    <ShellContent Title="Producto Terminado" Icon="almacen_terminado.png" ContentTemplate="{DataTemplate views:PTView}" />
    <!--<FlyoutItem Title="Almacen Refacciones" Icon="control_mapsa.ico">
        <ShellContent ContentTemplate="{DataTemplate views:MainView}" />
    </FlyoutItem>
    <FlyoutItem Title="Producto Terminado" Icon="almacen_terminado.png">
        <ShellContent ContentTemplate="{DataTemplate views:PTView}" />
    </FlyoutItem>

    <FlyoutItem Title="Login" Icon="login.png">
        <ShellContent ContentTemplate="{DataTemplate views:LoginView}" />
    </FlyoutItem>-->
    <Shell.FlyoutFooter>
        <StackLayout BackgroundColor="#FAA61A" Padding="10" VerticalOptions="End">
            <Button ImageSource="stand_by.png" Text="Cerrar Sesión" BackgroundColor="#FAA61A" TextColor="White" Clicked="CerrarSesion_Clicked" />
        </StackLayout>
    </Shell.FlyoutFooter>
</Shell>